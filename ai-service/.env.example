# AI Service Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Application
# ===========================================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=dev  # dev | demo | production

# ===========================================
# Backend Integration
# ===========================================
BACKEND_BASE_URL=http://localhost:8080

# ===========================================
# Shared Internal Service Secret
# ===========================================
# Shared secret for Backend <-> AI Service internal calls.
# MUST match AI_SERVICE_KEY in backend/.env
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AI_SERVICE_KEY=your-ai-service-key-here

# ===========================================
# LLM Provider (OpenRouter)
# ===========================================
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model per Agent (OpenRouter model IDs)
# See: https://openrouter.ai/models
AI_MODEL_GUARDRAILS=google/gemini-3.1-pro-preview
AI_MODEL_SQL=openai/gpt-5.4-mini
AI_MODEL_REPAIR=anthropic/claude-sonnet-4.6
AI_MODEL_ANALYSIS=anthropic/claude-haiku-4.5
AI_MODEL_VISUALIZATION=anthropic/claude-haiku-4.5
AI_MODEL_EMBEDDING=openai/text-embedding-3-small

# Embedding Guardrails
EMBEDDING_GUARDRAILS_ENABLED=true
EMBEDDING_SIMILARITY_HIGH_THRESHOLD=0.58
EMBEDDING_SIMILARITY_MEDIUM_THRESHOLD=0.35

# ===========================================
# SQL Execution Limits
# ===========================================
SQL_MAX_ROWS=500
SQL_DEFAULT_LIMIT=100
SQL_MAX_RETRIES=2
QUERY_TIMEOUT_SECONDS=10

# ===========================================
# Session & Memory
# ===========================================
SESSION_IDLE_TTL_MINUTES=60
CHAT_MEMORY_PAIRS=4

# ===========================================
# Schema Cache
# ===========================================
SCHEMA_CACHE_TTL_SECONDS=300

# ===========================================
# Development Mode
# ===========================================
# Set to "true" to use mock responses without calling LLM providers
AI_MOCK_MODE=false
