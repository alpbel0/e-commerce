{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "ecommerce-frontend": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "index": "src/index.html",
            "tsConfig": "tsconfig.app.json",
            "polyfills": [
              "zone.js"
            ],
            "assets": [],
            "styles": [
              "src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "development": {
              "optimization": false,
              "sourceMap": true
            },
            "production": {
              "optimization": true,
              "sourceMap": false
            }
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "ecommerce-frontend:build"
          },
          "configurations": {
            "development": {
              "buildTarget": "ecommerce-frontend:build:development"
            },
            "production": {
              "buildTarget": "ecommerce-frontend:build:production"
            }
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "5b7e4b7d-d990-413f-9786-f8fed20f84ef"
  }
}
