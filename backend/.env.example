# Backend Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Database
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=e-commerce
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ===========================================
# JWT
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-256-bit-jwt-secret-here
JWT_EXPIRATION_MS=86400000

# ===========================================
# AI Service Integration
# ===========================================
# Shared secret for Backend <-> AI Service internal communication
# MUST match AI_SERVICE_KEY in ai-service/.env
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AI_SERVICE_KEY=your-256-bit-secret-here

# AI Service base URL for backend calling AI
AI_SERVICE_BASE_URL=http://localhost:8000
CHATBOT_QUERY_TIMEOUT_SECONDS=10

# ===========================================
# Server
# ===========================================
SERVER_PORT=8080

# ===========================================
# CORS (for development only)
# ===========================================
CORS_ALLOWED_ORIGINS=http://localhost:4200
